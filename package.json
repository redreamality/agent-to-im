{
  "name": "claude-to-floatboat",
  "version": "0.1.0",
  "description": "Bridge between Floatboat Channel (MQTT/Protobuf) and Claude Code via claude-agent-sdk",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsx src/daemon.ts",
    "start": "node --import tsx/esm src/daemon.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.62",
    "mqtt": "^5.10.1",
    "protobufjs": "^7.4.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
